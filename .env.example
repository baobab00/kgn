# .env.example
KGN_DB_HOST=localhost
KGN_DB_PORT=5433
KGN_DB_NAME=kgn
KGN_DB_USER=kgn
KGN_DB_PASSWORD=kgn_dev_password
KGN_DB_POOL_MIN=1
KGN_DB_POOL_MAX=5
KGN_DB_POOL_TIMEOUT=10.0            # Connection pool wait timeout (seconds)
KGN_DB_POOL_MAX_IDLE=300.0          # Max idle connection lifetime (seconds)
KGN_DB_POOL_RECONNECT_TIMEOUT=30.0  # Reconnect timeout (seconds)

# Embedding / Conflict detection (optional)
# If openai package is not installed, only embedding features are disabled; core CLI works normally
KGN_OPENAI_API_KEY=sk-your-api-key-here
KGN_OPENAI_EMBED_MODEL=text-embedding-3-small    # Default; verify dimension compatibility if changed

# Conflict scan node count warning threshold (default 500)
# Emits O(n²) warning log when scan() target nodes exceed this value
KGN_CONFLICT_SCAN_WARN_THRESHOLD=500

# MCP server settings
KGN_MCP_TRANSPORT=stdio
KGN_MCP_PORT=8000

# Logging
KGN_LOG_LEVEL=INFO
KGN_LOG_FORMAT=json           # json | console

# Git/GitHub sync
GITHUB_TOKEN=ghp_your-github-personal-access-token
KGN_SYNC_DIR=./kgn-sync                    # Default sync directory
KGN_GIT_TIMEOUT=30                          # Git subprocess timeout (seconds, R-019)
